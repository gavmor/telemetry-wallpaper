{
  "id": "telemetry-wallpaper",
  "name": "Telemetry Wallpaper",
  "description": "Real-time token usage telemetry as a Cinnamon desktop background.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "spikeThreshold": {
        "type": "number",
        "default": 50000
      },
      "resolution": {
        "type": "string",
        "default": "1920x1080"
      },
      "theme": {
        "type": "string",
        "default": "gruvbox-dark"
      },
      "wallpaperCommand": {
        "type": "array",
        "items": { "type": "string" },
        "description": "The command to set the wallpaper. Example: ['/usr/bin/feh', '--bg-fill', '$PATH']"
      },
      "wallpaperOptions": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
